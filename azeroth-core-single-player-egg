    "scripts": {
        "installation": {
            "script": "#!/bin/bash\n# ============================================================================\n# ASP (AzerothCore Single Player) \u2014 Pelican install script.\n#\n# Runs in the install container (debian + curl/jq/p7zip) BEFORE the server\n# ever starts. Pelican mounts the persistent server directory at /mnt/server\n# during install (it becomes /home/container at runtime).\n#\n# Behaviour:\n#   * Fresh install (no Server/worldserver.exe present, or ASP_FORCE_FULL=1)\n#       \u2192 download every  ASP_<ver>_full.7z.NNN  asset\n#   * Existing install   \u2192 download every  ASP_<ver>_update_only.7z.NNN  asset\n#   * Reassemble + extract the multi-part 7z, then locate the inner\n#     \"Server\" folder and stage it at  /mnt/server/Server\n#   * Record the installed version in  /mnt/server/.asp/installed_version\n#\n# Release source: https://github.com/kadeshar/ASP/releases/latest\n# Override with ASP_RELEASE_REPO / ASP_RELEASE_TAG if you mirror it.\n# ============================================================================\n\nset -euo pipefail\n\n# --- Ensure required tools exist in the install container ------------------\n# The stock Pelican installers:debian image does NOT ship jq/7z. Install\n# them before anything else uses them. Idempotent: only runs apt if a tool\n# is actually missing, so re-installs stay fast.\nif ! command -v jq   >/dev/null 2>&1 \\\n   || ! command -v curl >/dev/null 2>&1 \\\n   || ! command -v 7z   >/dev/null 2>&1; then\n    echo \"==> Bootstrapping install dependencies (jq, curl, p7zip)\"\n    apt-get update\n    apt-get install -y --no-install-recommends \\\n        curl ca-certificates jq p7zip-full\nfi\n\nREPO=\"${ASP_RELEASE_REPO:-kadeshar/ASP}\"\nTAG=\"${ASP_RELEASE_TAG:-latest}\"\nTARGET=\"/mnt/server\"\nSTATE_DIR=\"${TARGET}/.asp\"\nVERSION_FILE=\"${STATE_DIR}/installed_version\"\n# Download/extract scratch space. MUST live on the mounted server volume\n# (/mnt/server) \u2014 the install container's /tmp is a small tmpfs and a ~2GB\n# part overflows it with \"curl: (23) Failure writing output to destination\".\n# Cleaned up at the end of this script.\nWORK=\"${TARGET}/.asp-dl\"\n\nmkdir -p \"$TARGET\" \"$STATE_DIR\" \"$WORK\"\n\necho \"==> ASP installer starting\"\necho \"    repo  : ${REPO}\"\necho \"    tag   : ${TAG}\"\necho \"    target: ${TARGET}\"\n\n# --- Resolve the release JSON ----------------------------------------------\nif [ \"$TAG\" = \"latest\" ]; then\n    API=\"https://api.github.com/repos/${REPO}/releases/latest\"\nelse\n    API=\"https://api.github.com/repos/${REPO}/releases/tags/${TAG}\"\nfi\n\nAUTH_HEADER=()\n[ -n \"${ASP_GITHUB_TOKEN:-}\" ] && AUTH_HEADER=(-H \"Authorization: Bearer ${ASP_GITHUB_TOKEN}\")\n\nREL_JSON=\"$(curl -fsSL \"${AUTH_HEADER[@]}\" \\\n    -H \"Accept: application/vnd.github+json\" \"$API\")\" \\\n    || { echo \"!! Could not query GitHub release API\"; exit 1; }\n\nREL_TAG=\"$(echo \"$REL_JSON\" | jq -r '.tag_name')\"\necho \"==> Resolved release: ${REL_TAG}\"\n\n# --- Decide full vs update_only --------------------------------------------\nMODE=\"full\"\nif [ -f \"${TARGET}/Server/worldserver.exe\" ] && [ \"${ASP_FORCE_FULL:-0}\" != \"1\" ]; then\n    MODE=\"update_only\"\nfi\nPREV_VER=\"\"\n[ -f \"$VERSION_FILE\" ] && PREV_VER=\"$(cat \"$VERSION_FILE\" 2>/dev/null || true)\"\n\nif [ \"$MODE\" = \"update_only\" ] && [ \"$PREV_VER\" = \"$REL_TAG\" ]; then\n    echo \"==> Already at ${REL_TAG} and a Server install exists. Nothing to do.\"\n    echo \"    (Set ASP_FORCE_FULL=1 to force a clean full reinstall.)\"\n    exit 0\nfi\necho \"==> Install mode: ${MODE}  (previous: ${PREV_VER:-none})\"\n\n# --- Select the matching multi-part assets ---------------------------------\n# Names look like: ASP_1.3.1_full.7z.001 / ASP_1.3.1_update_only.7z.002\nmapfile -t ASSETS < <(echo \"$REL_JSON\" | jq -r \\\n    --arg mode \"$MODE\" \\\n    '.assets[] | select(.name | test(\"_\" + $mode + \"\\\\.7z\\\\.[0-9]+$\"))\n     | \"\\(.name)\\t\\(.browser_download_url)\"' | sort)\n\nif [ \"${#ASSETS[@]}\" -eq 0 ]; then\n    echo \"!! No '${MODE}' .7z part assets found on release ${REL_TAG}.\"\n    if [ \"$MODE\" = \"update_only\" ]; then\n        echo \"   Falling back to a full install.\"\n        MODE=\"full\"\n        mapfile -t ASSETS < <(echo \"$REL_JSON\" | jq -r \\\n            '.assets[] | select(.name | test(\"_full\\\\.7z\\\\.[0-9]+$\"))\n             | \"\\(.name)\\t\\(.browser_download_url)\"' | sort)\n    fi\nfi\n[ \"${#ASSETS[@]}\" -eq 0 ] && { echo \"!! Still no parts found. Aborting.\"; exit 1; }\n\necho \"==> ${#ASSETS[@]} part(s) to download:\"\nfor a in \"${ASSETS[@]}\"; do echo \"    - ${a%%$'\\t'*}\"; done\n\n# --- Download every part ---------------------------------------------------\ncd \"$WORK\"\nrm -f ./*.7z.* 2>/dev/null || true\nfor a in \"${ASSETS[@]}\"; do\n    name=\"${a%%$'\\t'*}\"\n    url=\"${a##*$'\\t'}\"\n    echo \"==> Downloading ${name}\"\n    curl -fL --retry 5 --retry-delay 5 -C - \"${AUTH_HEADER[@]}\" \\\n        -o \"${WORK}/${name}\" \"$url\" \\\n        || { echo \"!! Download failed: ${name}\"; exit 1; }\ndone\n\n# --- Reassemble + extract ---------------------------------------------------\nFIRST_PART=\"$(ls \"${WORK}\"/*.7z.001 2>/dev/null | head -1 || true)\"\n[ -z \"$FIRST_PART\" ] && { echo \"!! No .7z.001 part present after download.\"; exit 1; }\n\nEXTRACT_DIR=\"${WORK}/extracted\"\nrm -rf \"$EXTRACT_DIR\"; mkdir -p \"$EXTRACT_DIR\"\n\necho \"==> Extracting $(basename \"$FIRST_PART\") (7z auto-joins .001/.002/...)\"\nif command -v 7z >/dev/null 2>&1;  then SEVENZIP=7z;\nelif command -v 7za >/dev/null 2>&1; then SEVENZIP=7za;\nelif command -v 7zr >/dev/null 2>&1; then SEVENZIP=7zr;\nelse echo \"!! No 7z binary in install container.\"; exit 1; fi\n\n# Large LZMA2 archives can exceed the install container's memory limit and\n# get OOM-killed (\"Killed\" / exit 137). Extract single-threaded (-mmt=1)\n# and, if still killed, retry once more conservatively. If both fail it is\n# almost certainly the server's Memory limit being too low \u2014 say so plainly.\nextract_archive() {\n    \"$SEVENZIP\" x -y -mmt=1 -o\"$EXTRACT_DIR\" \"$FIRST_PART\" >/dev/null 2>&1\n}\nextract_archive\nRC=$?\nif [ \"$RC\" -ne 0 ]; then\n    echo \"   First extraction attempt failed (rc=${RC}); retrying once...\"\n    rm -rf \"$EXTRACT_DIR\"; mkdir -p \"$EXTRACT_DIR\"\n    extract_archive\n    RC=$?\nfi\nif [ \"$RC\" -ne 0 ]; then\n    echo \"!! 7z extraction failed (rc=${RC}).\"\n    if [ \"$RC\" -eq 137 ] || [ \"$RC\" -eq 143 ]; then\n        echo \"!! Exit ${RC} = the process was KILLED, almost always the\"\n        echo \"!! server's Memory limit being too low for decompression.\"\n        echo \"!! Raise this server's Memory limit (8192MB+ recommended)\"\n        echo \"!! in the panel, then Reinstall.\"\n    fi\n    exit 1\nfi\n\n# Parts are now extracted \u2014 free the multi-GB .7z parts before the copy\n# step so peak disk stays ~1 archive-size instead of 3x.\necho \"==> Extraction OK, removing downloaded archive parts to save space\"\nrm -f \"${WORK}\"/*.7z.* 2>/dev/null || true\n\n# --- Locate the inner Server folder ----------------------------------------\n# The archive may extract as ./Server, ./ASP/Server, ./ASP_x.y.z/Server, etc.\necho \"==> Locating the Server folder (contains worldserver.exe)\"\nSERVER_SRC=\"$(find \"$EXTRACT_DIR\" -maxdepth 6 -type f -name worldserver.exe \\\n              -printf '%h\\n' 2>/dev/null | head -1)\"\nif [ -z \"$SERVER_SRC\" ]; then\n    # update_only archives may ship loose files without the .exe \u2014 fall back\n    # to a directory literally named \"Server\".\n    SERVER_SRC=\"$(find \"$EXTRACT_DIR\" -maxdepth 6 -type d -name Server 2>/dev/null | head -1)\"\nfi\n[ -z \"$SERVER_SRC\" ] && { echo \"!! Could not find a Server folder in the archive.\"; exit 1; }\necho \"    Found: ${SERVER_SRC}\"\n\n# --- Stage into the persistent volume --------------------------------------\nmkdir -p \"${TARGET}/Server\"\nif [ \"$MODE\" = \"full\" ]; then\n    echo \"==> Full install: syncing Server/ into ${TARGET}/Server\"\n    # Preserve player data + saves + DB across a forced full reinstall.\n    cp -a \"${SERVER_SRC}/.\" \"${TARGET}/Server/\" 2>/dev/null \\\n        || { echo \"!! Copy of Server/ failed.\"; exit 1; }\nelse\n    echo \"==> Update: overlaying changed files onto existing Server/\"\n    cp -a \"${SERVER_SRC}/.\" \"${TARGET}/Server/\" 2>/dev/null \\\n        || { echo \"!! Overlay copy failed.\"; exit 1; }\n    # Some update archives also ship a top-level Updates/ or SQL/ \u2014 copy any\n    # sibling folders alongside Server so manual SQL stays reachable.\n    PARENT=\"$(dirname \"$SERVER_SRC\")\"\n    for extra in Updates SQL Installations; do\n        [ -d \"${PARENT}/${extra}\" ] && cp -a \"${PARENT}/${extra}\" \"${TARGET}/\" 2>/dev/null || true\n    done\nfi\n\n# --- Make the config tree exist where the orchestrator expects it ----------\nmkdir -p \"${TARGET}/Server/configs/modules\" \"${TARGET}/Saves\" \"${STATE_DIR}\"\n\n# Stamp the version + stage the orchestrator/helper.\necho \"$REL_TAG\" > \"$VERSION_FILE\"\necho \"==> Installed version recorded: ${REL_TAG}\"\n\n# Pull the runtime helper scripts shipped with the egg (baked into the\n# runtime image at /usr/local/bin won't exist in the install container, so\n# the egg's runtime image provides them; here we just ensure the dirs).\nchmod -R u+rwX \"${TARGET}/Server\" 2>/dev/null || true\n\n# Cleanup scratch space so it doesn't bloat the install layer.\nrm -rf \"$WORK\"\n\necho \"==> ASP install/update complete (${MODE}, ${REL_TAG}).\"\necho \"    Server staged at ${TARGET}/Server\"",
            "container": "ghcr.io/pterodactyl/installers:debian",
            "entrypoint": "bash"
        }
    },
